# Windows ARM64 (MSVC ABI) via clang-cl + lld-link + xwin, cross-compiled from
# Linux. Identical to configs/xwin.config (the x86_64 baseline) except for the
# target architecture (--target / /MACHINE / xwin splat lib subdir).
#   XWIN_SPLAT=~/.xwin/splat putup configure --config configs/arm64.config -B build-arm64
CONFIG_OS_API=win32
CONFIG_OBJ_EXT=obj
CONFIG_LIB_EXT=lib
CONFIG_EXE_EXT=.exe
CONFIG_XWIN=y
CONFIG_XWIN_ARCH=aarch64

CONFIG_CC=clang-cl
CONFIG_CXX=clang-cl
CONFIG_AR=llvm-lib
CONFIG_RC=llvm-rc
CONFIG_LINKER=lld-link

CONFIG_CFLAGS=--target=aarch64-pc-windows-msvc /std:c11 /nologo /W3 /source-charset:utf-8 /D_CRT_SECURE_NO_DEPRECATE /D_CRT_SECURE_NO_WARNINGS /DNOMINMAX /D_ALLOW_COMPILER_AND_STL_VERSION_MISMATCH /MT /O2 /DNDEBUG
CONFIG_CXXFLAGS=--target=aarch64-pc-windows-msvc /std:c++17 /nologo /W3 /EHsc /source-charset:utf-8 /D_CRT_SECURE_NO_DEPRECATE /D_CRT_SECURE_NO_WARNINGS /DNOMINMAX /D_ALLOW_COMPILER_AND_STL_VERSION_MISMATCH /MT /O2 /DNDEBUG
CONFIG_LDFLAGS=/MANIFEST:NO /MACHINE:ARM64
CONFIG_RCFLAGS=/nologo

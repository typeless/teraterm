# Windows x86_64 (MSVC ABI) via clang-cl + lld-link + xwin, cross-compiled from Linux.
#
# clang-cl compiles and lld-link links against an xwin-splatted MSVC CRT +
# Windows SDK. The splat location is host-specific, so it is injected from the
# XWIN_SPLAT environment variable in Tuprules.tup (see `ifeq (@(XWIN),y)`), not
# baked here. Select with:
#   XWIN_SPLAT=~/.xwin/splat putup configure --config configs/xwin.config -B build-win
CONFIG_OS_API=win32
CONFIG_OBJ_EXT=obj
CONFIG_LIB_EXT=lib
CONFIG_EXE_EXT=.exe
CONFIG_XWIN=y
# xwin splat lib-subdir arch (crt/lib, sdk/lib/ucrt, sdk/lib/um). Matches the
# link target below. Per-arch configs override this (x86 / aarch64).
CONFIG_XWIN_ARCH=x86_64

# Toolchain (LLVM, MSVC-compatible drivers). Provide these on PATH:
#   clang-cl -> clang-cl-18, lld-link -> LLVM lld, llvm-lib, llvm-rc -> llvm-rc-18
CONFIG_CC=clang-cl
CONFIG_CXX=clang-cl
CONFIG_AR=llvm-lib
CONFIG_RC=llvm-rc
CONFIG_LINKER=lld-link

# Flags. --target lets clang-cl emit MSVC-ABI code on a Linux host. Tera Term's
# sources are UTF-8 (Japanese comments) -> /source-charset:utf-8, mirroring the
# CMake build. /W3 (not /WX) matches CMake's default warning level. /MT = static
# CRT so binaries carry no MSVC runtime DLL dependency.
CONFIG_CFLAGS=--target=x86_64-pc-windows-msvc /std:c11 /nologo /W3 /source-charset:utf-8 /D_CRT_SECURE_NO_DEPRECATE /D_CRT_SECURE_NO_WARNINGS /DNOMINMAX /D_ALLOW_COMPILER_AND_STL_VERSION_MISMATCH /MT /O2 /DNDEBUG
CONFIG_CXXFLAGS=--target=x86_64-pc-windows-msvc /std:c++17 /nologo /W3 /EHsc /source-charset:utf-8 /D_CRT_SECURE_NO_DEPRECATE /D_CRT_SECURE_NO_WARNINGS /DNOMINMAX /D_ALLOW_COMPILER_AND_STL_VERSION_MISMATCH /MT /O2 /DNDEBUG
CONFIG_LDFLAGS=/MANIFEST:NO /MACHINE:X64
CONFIG_RCFLAGS=/nologo

include_rules

# TTXKcodeChange.dll — standalone sample TTX plugin (no common_static/ttpcmn).
# Wraps recv() via the TTX hook function pointer, so no ws2_32 import is needed.
CFLAGS += -I$(S)/teraterm/common -I$(S)/teraterm/teraterm

srcs_c += TTXKcodeChange.c

: foreach $(srcs_c) |> !cc |> {objs}

LDFLAGS += /DLL /IMPLIB:$(TUP_VARIANT_OUTPUTDIR)/TTXKcodeChange.lib
LDFLAGS += user32.lib gdi32.lib advapi32.lib shell32.lib comdlg32.lib
: {objs} |> !link |> TTXKcodeChange.dll | TTXKcodeChange.lib <implib>

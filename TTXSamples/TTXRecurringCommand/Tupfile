include_rules

# TTXRecurringCommand.dll — links common_static + ttpcmn; has a dialog resource.
CFLAGS += -I$(S)/teraterm/common -I$(S)/teraterm/teraterm
RCFLAGS += /I $(S)/TTXSamples/TTXRecurringCommand

srcs_c += TTXRecurringCommand.c
srcs_rc += TTXRecurringCommand.rc

: foreach $(srcs_c) |> !cc |> {objs}
: foreach $(srcs_rc) |> !rc |> {res}

LDFLAGS += /DLL /IMPLIB:$(TUP_VARIANT_OUTPUTDIR)/TTXRecurringCommand.lib
LDFLAGS += user32.lib gdi32.lib comdlg32.lib advapi32.lib shell32.lib ole32.lib oleaut32.lib uuid.lib
LDFLAGS += shlwapi.lib comctl32.lib winspool.lib winmm.lib imm32.lib version.lib setupapi.lib imagehlp.lib gdiplus.lib
: {objs} {res} $(S)/teraterm/common/common_static.lib $(S)/teraterm/ttpcmn/ttpcmn.lib |> !link |> TTXRecurringCommand.dll | TTXRecurringCommand.lib <implib>

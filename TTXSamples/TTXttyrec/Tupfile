include_rules

# Two plugins from one dir: TTXttyplay.dll and TTXttyrec.dll, both linking
# common_static + ttpcmn and sharing gettimeofday.obj. recv() is wrapped through
# the TTX hook function pointer, so no ws2_32 import is needed.
# No explicit /IMPLIB: with two DLLs sharing one LDFLAGS, each import lib is
# derived from its own /OUT (TTXttyplay.lib / TTXttyrec.lib).
CFLAGS += -I$(S)/teraterm/common -I$(S)/teraterm/teraterm

: foreach TTXttyplay.c |> !cc |> {play_objs}
: foreach TTXttyrec.c |> !cc |> {rec_objs}
: foreach gettimeofday.c |> !cc |> {shared_objs}

LDFLAGS += /DLL
LDFLAGS += user32.lib gdi32.lib comdlg32.lib advapi32.lib shell32.lib ole32.lib oleaut32.lib uuid.lib
LDFLAGS += shlwapi.lib comctl32.lib winspool.lib winmm.lib imm32.lib version.lib setupapi.lib imagehlp.lib gdiplus.lib
: {play_objs} {shared_objs} $(S)/teraterm/common/common_static.lib $(S)/teraterm/ttpcmn/ttpcmn.lib |> !link |> TTXttyplay.dll | TTXttyplay.lib <implib>
: {rec_objs} {shared_objs} $(S)/teraterm/common/common_static.lib $(S)/teraterm/ttpcmn/ttpcmn.lib |> !link |> TTXttyrec.dll | TTXttyrec.lib <implib>

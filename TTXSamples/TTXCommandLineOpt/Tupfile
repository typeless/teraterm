include_rules

# TTXCommandLineOpt.dll — links ttpcmn only (no common_static).
CFLAGS += -I$(S)/teraterm/common -I$(S)/teraterm/teraterm

srcs_c += TTXCommandLineOpt.c

: foreach $(srcs_c) |> !cc |> {objs}

LDFLAGS += /DLL /IMPLIB:$(TUP_VARIANT_OUTPUTDIR)/TTXCommandLineOpt.lib
LDFLAGS += user32.lib gdi32.lib advapi32.lib shell32.lib comdlg32.lib
: {objs} $(S)/teraterm/ttpcmn/ttpcmn.lib |> !link |> TTXCommandLineOpt.dll | TTXCommandLineOpt.lib <implib>

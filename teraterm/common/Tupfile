include_rules

# Generated version stamp: reuse the existing perl generator to emit svnversion.h
# into this directory's build output. common's objects order-depend on it (<gen>).
GENDIR = $(TUP_VARIANT_OUTPUTDIR)
# svnrev.pl also emits sourcetree_info.bat (default name, into CWD) -> redirect it
# into the build dir so it does not pollute the source tree.
: |> ^ GEN svnversion.h^ perl $(S)/buildtools/svnrev/svnrev.pl --root $(S) --header %o --bat $(TUP_VARIANT_OUTPUTDIR)/sourcetree_info.bat --architecture x86_64 |> svnversion.h | sourcetree_info.bat <gen>

# common headers are included ""-style from each source's own dir (automatic);
# sibling dirs and the generated-header dir are added explicitly.
CFLAGS += -I$(S)/teraterm/common -I$(S)/teraterm/teraterm -I$(S)/teraterm/susie_plugin -I$(GENDIR)
CXXFLAGS += -I$(S)/teraterm/common -I$(S)/teraterm/teraterm -I$(S)/teraterm/susie_plugin -I$(GENDIR)


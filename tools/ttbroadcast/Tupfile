include_rules

# ttbroadcast: console tool that broadcasts input to all Tera Term windows.
# wmain entry (wide argv). Compiles getopt.c (STATIC_GETOPT) directly; links
# ttpcmn (import lib) + common_static for codeconv/asprintf/etc. STATIC_GETOPT
# must reach both the C (getopt.c) and C++ (main.cpp) TUs since getopt.h keys
# symbol linkage off it.
CFLAGS += -DSTATIC_GETOPT
CXXFLAGS += -DSTATIC_GETOPT
CFLAGS += -I$(S)/teraterm/common -I$(S)/tools/libs/getopt_mb_uni_src
CXXFLAGS += -I$(S)/teraterm/common -I$(S)/tools/libs/getopt_mb_uni_src

srcs_cpp += main.cpp
srcs_c += $(S)/tools/libs/getopt_mb_uni_src/getopt.c

: foreach $(srcs_cpp) |> !cxx |> {objs}
: foreach $(srcs_c) |> !cc |> {objs}

LDFLAGS += /SUBSYSTEM:CONSOLE /ENTRY:wmainCRTStartup
LDFLAGS += kernel32.lib user32.lib gdi32.lib comdlg32.lib advapi32.lib shell32.lib ole32.lib oleaut32.lib uuid.lib
LDFLAGS += shlwapi.lib comctl32.lib winspool.lib winmm.lib imm32.lib version.lib setupapi.lib imagehlp.lib gdiplus.lib

: {objs} $(S)/teraterm/ttpcmn/ttpcmn.lib $(S)/teraterm/common/common_static.lib |> !link |> ttbroadcast$(_exe)

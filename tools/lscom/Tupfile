include_rules

# lscom: console tool that lists available COM ports. wmain entry (wide argv).
# Compiles ttpcmn/ttcmn_cominfo.c and getopt.c (STATIC_GETOPT) directly, and
# links common_static for comportinfo/codeconv/etc. STATIC_GETOPT must reach
# both the C (getopt.c) and C++ (main.cpp) TUs since getopt.h keys symbol
# linkage off it.
CFLAGS += -DSTATIC_GETOPT
CXXFLAGS += -DSTATIC_GETOPT
CFLAGS += -I$(S)/teraterm/common -I$(S)/teraterm/ttpcmn -I$(S)/tools/libs/getopt_mb_uni_src
CXXFLAGS += -I$(S)/teraterm/common -I$(S)/teraterm/ttpcmn -I$(S)/tools/libs/getopt_mb_uni_src

srcs_cpp += main.cpp
srcs_c += iswindowsntkernel.c
srcs_c += $(S)/teraterm/ttpcmn/ttcmn_cominfo.c
srcs_c += $(S)/tools/libs/getopt_mb_uni_src/getopt.c

: foreach $(srcs_cpp) |> !cxx |> {objs}
: foreach $(srcs_c) |> !cc |> {objs}

LDFLAGS += /SUBSYSTEM:CONSOLE /ENTRY:wmainCRTStartup
LDFLAGS += kernel32.lib user32.lib gdi32.lib comdlg32.lib advapi32.lib shell32.lib ole32.lib oleaut32.lib uuid.lib
LDFLAGS += shlwapi.lib comctl32.lib winspool.lib winmm.lib imm32.lib version.lib setupapi.lib imagehlp.lib gdiplus.lib

: {objs} $(S)/teraterm/common/common_static.lib |> !link |> lscom$(_exe)

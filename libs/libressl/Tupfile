# Windows/clang-cl: include/compat POSIX shims + compat/*_win.c.
INCS = -I$(S)/libs/libressl/crypto -I$(S)/libs/libressl/crypto/aes -I$(S)/libs/libressl/crypto/asn1 -I$(S)/libs/libressl/crypto/bio -I$(S)/libs/libressl/crypto/bn -I$(S)/libs/libressl/crypto/bytestring -I$(S)/libs/libressl/crypto/conf -I$(S)/libs/libressl/crypto/dh -I$(S)/libs/libressl/crypto/dsa -I$(S)/libs/libressl/crypto/curve25519 -I$(S)/libs/libressl/crypto/ec -I$(S)/libs/libressl/crypto/ecdh -I$(S)/libs/libressl/crypto/ecdsa -I$(S)/libs/libressl/crypto/err -I$(S)/libs/libressl/crypto/evp -I$(S)/libs/libressl/crypto/hidden -I$(S)/libs/libressl/crypto/hmac -I$(S)/libs/libressl/crypto/lhash -I$(S)/libs/libressl/crypto/mlkem -I$(S)/libs/libressl/crypto/modes -I$(S)/libs/libressl/crypto/ocsp -I$(S)/libs/libressl/crypto/pkcs12 -I$(S)/libs/libressl/crypto/rsa -I$(S)/libs/libressl/crypto/sha -I$(S)/libs/libressl/crypto/stack -I$(S)/libs/libressl/crypto/x509 -I$(S)/libs/libressl/include/compat -I$(S)/libs/libressl/include -I$(S)/libs/libressl/crypto/arch/amd64 -I$(S)/libs/libressl/crypto/bn/arch/amd64
DEFS = -DWIN32_LEAN_AND_MEAN -DLIBRESSL_CRYPTO_INTERNAL -DLIBRESSL_INTERNAL -DOPENSSL_NO_ASM -DOPENSSL_NO_HW_PADLOCK -D__BEGIN_HIDDEN_DECLS= -D__END_HIDDEN_DECLS= -DOPENSSLDIR=\"etc/ssl\"
